# Zoom Connector Configuration

# Zoom App Credentials (get from Zoom Marketplace)
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret
ZOOM_REDIRECT_URI=http://localhost:8000/oauth/callback

# For Server-to-Server OAuth (optional, for bot-level access)
ZOOM_ACCOUNT_ID=

# OpenClaw Gateway
OPENCLAW_URL=http://localhost:8080
OPENCLAW_API_KEY=

# Bot Configuration
BOT_NAME=Zoom Team Chat Integration

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true
