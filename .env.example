# Zoom Connector Configuration

# === REQUIRED ===
# Your Zoom App ID (from Zoom Marketplace)
# Get this by creating a Chatbot app at https://marketplace.zoom.us/
# This is safe to share - it's the public identifier for your app
ZOOM_APP_ID=your_app_id_here

# === OPTIONAL ===
# Bot name (default: "Zoom Team Chat Integration")
BOT_NAME=Zoom Team Chat Integration

# Only fill these if not using pure OAuth flow:
# ZOOM_CLIENT_SECRET=your_client_secret

# OpenClaw Gateway
OPENCLAW_URL=http://localhost:8080
OPENCLAW_API_KEY=

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true
